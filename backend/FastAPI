"""
FastAPI routes for MedOps Orchestrator API

This file defines the API surface that the React frontend depends on.
Implement these routes by integrating with your orchestrator modules from:
  - foundation branch: decision functions, models, config
  - platform branch: orchestrator, agents, database

Usage:
  from fastapi import FastAPI
  from api_routes import setup_routes
  
  app = FastAPI()
  setup_routes(app)
"""

from fastapi import FastAPI, HTTPException, Depends, BackgroundTasks
from pydantic import BaseModel, Field
from typing import Optional, List, Dict, Any
from datetime import datetime, timedelta
from uuid import UUID, uuid4
from enum import Enum
import logging

logger = logging.getLogger(__name__)


# ============================================================================
# Request/Response Models (matching OpenAPI spec)
# ============================================================================

class HealthResponse(BaseModel):
    status: str = "ok"
    database: str = "connected"
    timestamp: datetime


class ProblemType(str, Enum):
    shortage = "shortage"
    excess = "excess"
    expiration = "expiration"
    supplier_delay = "supplier_delay"


class Scenario(BaseModel):
    id: int
    tag: str
    drug: str
    narrative: str
    approver_role: str
    correlation_id: str


class ScenarioDetail(Scenario):
    current_workflow_id: Optional[UUID] = None
    current_stage: Optional[str] = None


class RunScenarioRequest(BaseModel):
    override_config: Optional[Dict[str, Any]] = None


class RunScenarioResponse(BaseModel):
    workflow_id: UUID
    correlation_id: str
    status: str
    started_at: datetime


class WorkflowStage(str, Enum):
    detected = "detected"
    agents_consulted = "agents_consulted"
    options_ranked = "options_ranked"
    pending_approval = "pending_approval"
    approved = "approved"
    task_created = "task_created"
    in_progress = "in_progress"
    completed = "completed"
    rejected = "rejected"
    escalated = "escalated"


class RankedOption(BaseModel):
    option_id: str  # "transfer" or "procurement"
    label: str
    feasible: bool
    score: Optional[int] = None  # 0-100, None if not feasible
    availability_protection: Optional[float] = None  # 0.0-1.0
    lead_time_margin_days: Optional[int] = None
    cost_usd: Optional[float] = None
    waste_avoided_units: Optional[int] = None
    agent_responsible: str


class RejectedOption(BaseModel):
    option_id: str
    label: str
    reason: str  # Human-readable feasibility rejection reason


class Recommendation(BaseModel):
    recommendation_id: UUID
    version: int
    drug: str
    problem_type: ProblemType
    ranked_options: List[RankedOption]
    rejected_options: List[RejectedOption]
    scoring_weights: Dict[str, float]
    input_snapshot: Dict[str, Any]  # Inventory/supplier state at decision time
    policy_version: str
    generated_at: datetime


class ApprovalDecision(BaseModel):
    decision_id: UUID
    workflow_id: UUID
    recommendation_id: UUID
    recommendation_version: int
    approver_role: str
    approver_id: Optional[str] = None
    decision: str  # approved, rejected, escalated
    reason: Optional[str] = None  # Required for reject
    policy_version: str
    decided_at: datetime


class WorkflowState(BaseModel):
    workflow_id: UUID
    correlation_id: str
    drug: str
    stage: WorkflowStage
    version: int
    detected_at: datetime
    options_ranked_at: Optional[datetime] = None
    pending_approval_at: Optional[datetime] = None
    approved_at: Optional[datetime] = None
    
    recommendation: Optional[Recommendation] = None  # Only if stage >= options_ranked
    approval_decision: Optional[ApprovalDecision] = None  # Only if decided
    task_id: Optional[UUID] = None  # Only if task_created or later


class ApproveRequest(BaseModel):
    approver_role: str  # Manager, Pharmacist, Clinician
    approver_id: Optional[str] = None


class ApproveResponse(BaseModel):
    workflow_id: UUID
    status: str
    task_id: Optional[UUID] = None
    task_status: Optional[str] = None
    timestamp: datetime


class RejectRequest(BaseModel):
    approver_role: str
    approver_id: Optional[str] = None
    reason: str  # Must match enum in spec


class RejectResponse(BaseModel):
    workflow_id: UUID
    status: str  # rejected, pending_approval (if recalc), or escalated
    rejection_count: int
    next_version: Optional[int] = None  # If recalculation triggered
    timestamp: datetime


class EscalateRequest(BaseModel):
    reason: str


class EscalateResponse(BaseModel):
    workflow_id: UUID
    status: str
    timestamp: datetime


class TaskStatus(str, Enum):
    requested = "requested"
    assigned = "assigned"
    accepted = "accepted"
    in_progress = "in_progress"
    delayed = "delayed"
    completed = "completed"
    failed = "failed"
    escalated = "escalated"


class Task(BaseModel):
    task_id: UUID
    correlation_id: str  # Idempotency key
    workflow_id: UUID
    drug: str
    task_type: str  # transfer or procurement
    status: TaskStatus
    
    source_location: Optional[str] = None
    destination_location: Optional[str] = None
    quantity: int
    estimated_delivery_hours: Optional[int] = None
    
    supplier_name: Optional[str] = None
    estimated_arrival_date: Optional[datetime] = None
    
    steps_completed: List[str] = []
    created_at: datetime
    updated_at: datetime
    completed_at: Optional[datetime] = None


class ReassignRequest(BaseModel):
    pass  # No body needed; backend picks next available courier


class ReassignResponse(BaseModel):
    task_id: UUID
    status: TaskStatus
    timestamp: datetime


class LatencyMetrics(BaseModel):
    median: float
    p95: float


class KPIs(BaseModel):
    timestamp: datetime
    time_window_days: int
    
    problems_detected: int
    recommendations_generated: int
    recommendation_acceptance_rate_pct: float
    false_positive_rate_pct: float
    
    latency_detection_to_recommendation_sec: LatencyMetrics
    latency_recommendation_to_approval_sec: LatencyMetrics
    latency_approval_to_task_creation_sec: float
    latency_task_completion_sec: LatencyMetrics
    
    task_completion_rate_pct: float
    manual_coordination_steps_avoided: int
    estimated_operations_minutes_saved: float
    
    medication_availability_rate_pct: float
    potential_stockouts_addressed: int
    simulated_stockouts_prevented: int
    expiration_risk_quantity_redistributed: int
    transfer_vs_procurement_ratio: float
    invalid_recommendations_blocked: int


class Config(BaseModel):
    safety_stock_multiplier: float
    days_of_supply_minimum: int
    expiration_risk_horizon_days: int
    lead_time_buffer_days: int
    scoring_weights: Dict[str, float]
    minimum_feasibility_score: int
    retry_limit_delivery: int
    minutes_per_manual_coordination_step: int
    updated_at: datetime


